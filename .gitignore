# Build output / packaging — never committed. Each tag's dist/<tag>.7z is
# produced locally by ingest_release.py and uploaded as a GitHub Release asset.
dist/

# Scratch / research — never committed.
work/

# Sibling install archives that may exist in source folders.
*.7z
*.zip

# Binary content from release source folders. Per the v2 design,
# release/ ships only TEXT files in git; binaries live in dist/<tag>.7z
# (uploaded as GitHub Release assets) and are tracked via the per-binary
# *.md co-files alongside.
*.pak
*.ucas
*.utoc
*.dll
*.exe
*.dds
*.tga
*.png
*.jpg
*.jpeg
*.webp
*.uasset
*.uexp
*.umap
*.bsa
*.esp
*.esm

# Python.
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/

# Editor / OS.
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Logs.
*.log

# Local-only Claude settings (settings.json IS committed; *.local.json is per-user).
.claude/settings.local.json
