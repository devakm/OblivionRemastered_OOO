# Binary mod artifacts — store via Git LFS so the working repo stays small.
# IoStore container triplet:
*.pak    filter=lfs diff=lfs merge=lfs -text
*.ucas   filter=lfs diff=lfs merge=lfs -text
*.utoc   filter=lfs diff=lfs merge=lfs -text

# UE4SS / native tooling shipped inside releases:
*.dll    filter=lfs diff=lfs merge=lfs -text
*.exe    filter=lfs diff=lfs merge=lfs -text

# UE5 reflection / asset blobs occasionally bundled:
*.uasset filter=lfs diff=lfs merge=lfs -text
*.uexp   filter=lfs diff=lfs merge=lfs -text
*.umap   filter=lfs diff=lfs merge=lfs -text

# Magic Loader compiled blobs (if any ship as binary):
*.mlc    filter=lfs diff=lfs merge=lfs -text

# TES4 plugin/master files — binary, do delta-compress poorly:
*.esp    filter=lfs diff=lfs merge=lfs -text
*.esm    filter=lfs diff=lfs merge=lfs -text
*.bsa    filter=lfs diff=lfs merge=lfs -text

# Texture / image binaries that might appear in releases:
*.dds    filter=lfs diff=lfs merge=lfs -text
*.tga    filter=lfs diff=lfs merge=lfs -text
*.png    filter=lfs diff=lfs merge=lfs -text
*.jpg    filter=lfs diff=lfs merge=lfs -text
*.webp   filter=lfs diff=lfs merge=lfs -text

# Force LF for the small text files we DO want git diffs on:
*.json   text eol=lf
*.ini    text eol=lf
*.md     text eol=lf
*.py     text eol=lf
*.html   text eol=lf
*.css    text eol=lf
