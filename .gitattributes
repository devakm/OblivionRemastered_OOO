# Enforce LF line endings for the small text files we DO commit. This stops
# Windows checkouts from churning CRLF noise into JSON/INI/Lua diffs.
*.json   text eol=lf
*.ini    text eol=lf
*.md     text eol=lf
*.py     text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.lua    text eol=lf
*.txt    text eol=lf
*.csv    text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.toml   text eol=lf
*.xml    text eol=lf

# No LFS routing here — binaries do not enter the repo. They are produced as
# dist/<tag>.7z by ingest_release.py and uploaded as GitHub Release assets.
